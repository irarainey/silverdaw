{
  "name": "Hercules compact Inpulse family",
  "models": ["DJCONTROL STARLIGHT", "DJCONTROL MIX"],
  "sources": [
    "https://github.com/mixxxdj/mixxx/blob/main/res/controllers/Hercules%20DJControl%20Starlight.midi.xml",
    "https://github.com/mixxxdj/mixxx/blob/main/res/controllers/Hercules%20DJControl%20MIX.midi.xml"
  ],
  "inputs": [
    { "action": "playPause", "encoding": "button", "message": "note", "data1": 7, "channels": [1, 2], "decks": [1, 2] },
    { "action": "previousMarker", "encoding": "button", "message": "note", "data1": 6, "channels": [1, 2], "decks": [1, 2] },
    { "action": "nextMarker", "encoding": "button", "message": "note", "data1": 6, "channels": [4, 5], "decks": [1, 2] },
    { "action": "syncModifier", "encoding": "button", "message": "note", "data1": 5, "channels": [1, 2, 4, 5], "decks": [1, 2, 1, 2] },
    { "action": "deckToggle", "encoding": "button", "message": "note", "data1": 12, "channels": [1, 2], "decks": [1, 2] },
    { "action": "jogTouch", "encoding": "button", "message": "note", "data1": 8, "channels": [1, 2], "decks": [1, 2] },
    { "action": "jogScratch", "encoding": "relativeTwosComplement", "message": "cc", "data1": 10, "channels": [1, 2], "decks": [1, 2] },
    { "action": "jogPitchBend", "encoding": "relativeTwosComplement", "message": "cc", "data1": 9, "channels": [1, 2], "decks": [1, 2] },
    { "action": "trackGain", "encoding": "absolute7", "message": "cc", "data1": 0, "channels": [1, 2], "decks": [1, 2] },
    { "action": "toneBass", "encoding": "absolute7", "message": "cc", "data1": 2, "channels": [1, 2], "decks": [1, 2] },
    { "action": "filter", "encoding": "absolute7", "message": "cc", "data1": 1, "channels": [1, 2], "decks": [1, 2] },
    { "action": "crossfader", "encoding": "absolute7", "message": "cc", "data1": 0, "channels": [0], "decks": [0] },
    { "action": "markerJump", "encoding": "padRange", "message": "note", "data1": 0, "count": 4, "padOffset": 1, "channels": [6, 7], "decks": [1, 2] },
    { "action": "markerToggle", "encoding": "padRange", "message": "note", "data1": 8, "count": 4, "padOffset": 1, "channels": [6, 7], "decks": [1, 2] }
  ],
  "outputs": [
    { "purpose": "playLight", "message": "note", "data1": 7, "channels": [1, 2] },
    { "purpose": "cueLight", "message": "note", "data1": 6, "channels": [1, 2] },
    { "purpose": "deckSelectionLight", "message": "note", "data1": 12, "channels": [1, 2] },
    { "purpose": "hotCueLights", "message": "note", "data1": 0, "count": 4, "channels": [6, 7] }
  ]
}
