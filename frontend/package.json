{
  "name": "silverdaw",
  "version": "1.3.0",
  "description": "A remix-first DAW",
  "author": {
    "name": "Ira Rainey"
  },
  "private": true,
  "type": "module",
  "main": "out/main/index.js",
  "packageManager": "pnpm@11.15.0",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "lint": "eslint . --ext .ts,.vue",
    "typecheck": "vue-tsc --noEmit -p tsconfig.web.json --composite false && tsc --noEmit -p tsconfig.node.json --composite false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "dist": "electron-vite build && electron-builder --win --x64 --config electron-builder.yml",
    "dist:store": "electron-vite build && electron-builder --win --x64 --config electron-builder.store.cjs",
    "dist:dir": "electron-vite build && electron-builder --win --x64 --dir --config electron-builder.yml"
  },
  "dependencies": {
    "music-metadata": "^11.12.3",
    "pinia": "^2.2.0",
    "pixi.js": "^8.2.0",
    "vue": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "^42.5.2",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.27.0",
    "globals": "^17.6.0",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.0.0"
  }
}
